# Runtime mode
LFD_MODEL_MODE=real
LFD_DEVICE=auto
LFD_ALLOW_MOCK_FALLBACK=0

# Seeded reviewer event
LFD_SEED_SAMPLE=1
LFD_SEED_EVENT_ID=demo
LFD_SEED_EVENT_NAME=Demo Conference 2026
LFD_SEED_STAFF_PASSWORD=demo-pass

# Models, all under the Build Small 32B cap
LFD_MINICPM_V_MODEL=openbmb/MiniCPM-V-4.6
LFD_MINICPM5_MODEL=openbmb/MiniCPM5-1B
LFD_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2

# Retrieval
LFD_RETRIEVAL=1
LFD_MATCH_TOPK=10
LFD_EMBED_STRONG=0.32
LFD_EMBED_WEAK=0.18

# Optional observability
LFD_TELEMETRY=0
LFD_LOG_LEVEL=INFO
